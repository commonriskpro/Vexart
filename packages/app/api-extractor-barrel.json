{
  "$schema": "https://developer.microsoft.com/json-schemas/api-extractor/v7/api-extractor.schema.json",
  "projectFolder": ".",
  "mainEntryPointFilePath": "<projectFolder>/../../.api-extractor-temp/packages/app/src/barrel.d.ts",
  "apiReport": {
    "enabled": false
  },
  "docModel": {
    "enabled": false
  },
  "dtsRollup": {
    "enabled": true,
    "untrimmedFilePath": "<projectFolder>/../../types/vexart.d.ts"
  },
  "tsdocMetadata": {
    "enabled": false
  },
  "compiler": {
    "tsconfigFilePath": "<projectFolder>/../../tsconfig.api-extractor.json"
  },
  "messages": {
    "compilerMessageReporting": {
      "default": {
        "logLevel": "warning"
      }
    },
    "extractorMessageReporting": {
      "default": {
        "logLevel": "warning"
      },
      "ae-forgotten-export": {
        "logLevel": "none",
        "addToApiReportFile": false
      },
      "ae-missing-release-tag": {
        "logLevel": "none",
        "addToApiReportFile": false
      }
    },
    "tsdocMessageReporting": {
      "default": {
        "logLevel": "warning"
      }
    }
  }
}
