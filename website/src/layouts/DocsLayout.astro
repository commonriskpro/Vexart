---
const { title = 'Vexart Docs', description = 'Vexart documentation' } = Astro.props

const sections = [
  {
    label: 'Guides',
    items: [
      { href: '/guides/getting-started/', label: 'Getting Started' },
      { href: '/guides/examples-cookbook/', label: 'Examples Cookbook' },
      { href: '/guides/migration-tge-to-vexart/', label: 'Migration Guide' },
    ],
  },
  {
    label: 'Reference',
    items: [
      { href: '/reference/api-overview/', label: 'API Overview' },
      { href: '/reference/component-catalog/', label: 'Component Catalog' },
      { href: '/reference/architecture-overview/', label: 'Architecture Overview' },
      { href: '/reference/licensing/', label: 'Licensing' },
      { href: '/reference/distribution-packaging/', label: 'Distribution & Packaging' },
      { href: '/reference/private-beta/', label: 'Private Beta' },
    ],
  },
]
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <style>
      :root {
        color-scheme: dark;
        --bg: #09090b;
        --panel: #18181b;
        --text: #fafafa;
        --muted: #a1a1aa;
        --border: #27272a;
        --accent: #3b82f6;
      }
      * { box-sizing: border-box; }
      body {
        margin: 0;
        font-family: Inter, ui-sans-serif, system-ui, sans-serif;
        background: var(--bg);
        color: var(--text);
      }
      a { color: #93c5fd; text-decoration: none; }
      a:hover { text-decoration: underline; }
      .shell {
        display: grid;
        grid-template-columns: 280px 1fr;
        min-height: 100vh;
      }
      aside {
        border-right: 1px solid var(--border);
        padding: 24px 20px;
        background: #0b0b0f;
        position: sticky;
        top: 0;
        height: 100vh;
        overflow: auto;
      }
      main {
        padding: 32px 40px 72px;
        max-width: 920px;
      }
      .brand {
        margin-bottom: 24px;
      }
      .brand h1 {
        margin: 0 0 6px;
        font-size: 22px;
      }
      .brand p, .section-label, .muted { color: var(--muted); }
      .section-label {
        text-transform: uppercase;
        letter-spacing: .08em;
        font-size: 11px;
        margin: 20px 0 10px;
      }
      ul { list-style: none; padding: 0; margin: 0; }
      li + li { margin-top: 8px; }
      article {
        background: transparent;
      }
      article :global(h1) { font-size: 38px; margin: 0 0 16px; }
      article :global(h2) { margin-top: 32px; font-size: 24px; }
      article :global(h3) { margin-top: 24px; font-size: 18px; }
      article :global(p),
      article :global(li) { line-height: 1.7; color: #e4e4e7; }
      article :global(code) {
        background: #111827;
        padding: 2px 6px;
        border-radius: 6px;
      }
      article :global(pre) {
        background: #111827;
        border: 1px solid var(--border);
        padding: 16px;
        border-radius: 12px;
        overflow: auto;
      }
      .home-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
        gap: 16px;
      }
      .card {
        display: block;
        padding: 18px;
        border: 1px solid var(--border);
        border-radius: 14px;
        background: var(--panel);
      }
      .card strong { display: block; margin-bottom: 8px; color: var(--text); }
      @media (max-width: 900px) {
        .shell { grid-template-columns: 1fr; }
        aside { position: static; height: auto; border-right: 0; border-bottom: 1px solid var(--border); }
        main { padding: 24px 20px 48px; }
      }
    </style>
  </head>
  <body>
    <div class="shell">
      <aside>
        <div class="brand">
          <h1><a href="/">Vexart Docs</a></h1>
          <p>v0.9 developer preview foundation.</p>
        </div>
        {sections.map((section) => (
          <section>
            <div class="section-label">{section.label}</div>
            <ul>
              {section.items.map((item) => (
                <li><a href={item.href}>{item.label}</a></li>
              ))}
            </ul>
          </section>
        ))}
      </aside>
      <main>
        <article>
          <slot />
        </article>
      </main>
    </div>
  </body>
</html>
