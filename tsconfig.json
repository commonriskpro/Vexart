{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "baseUrl": ".",
    "jsx": "preserve",
    "jsxImportSource": "solid-js",
    "strict": true,
    "noEmit": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "paths": {
      "@tge/platform-terminal": ["./packages/platform-terminal/src/index.ts"],
      "@tge/terminal": ["./packages/terminal/src/index.ts"],
      "@tge/input": ["./packages/input/src/index.ts"],
      "@tge/renderer-solid": ["./packages/renderer-solid/src/index.ts"],
      "@tge/pixel": ["./packages/pixel/src/index.ts"],
      "@tge/output": ["./packages/output/src/index.ts"],
      "@tge/output-kitty": ["./packages/output-kitty/src/index.ts"],
      "@tge/renderer": ["./packages/renderer-solid/src/index.ts"],
      "@tge/renderer/*": ["./packages/renderer-solid/src/*"],
      "@tge/layout-clay": ["./packages/layout-clay/src/index.ts"],
      "@tge/gpu": ["./packages/gpu/src/index.ts"],
      "@tge/components": ["./packages/components/src/index.ts"],
      "@tge/void": ["./packages/void/src/index.ts"],
      "@vexart/engine": ["./packages/engine/src/index.ts"],
      "@vexart/primitives": ["./packages/primitives/src/index.ts"],
      "@vexart/headless": ["./packages/headless/src/index.ts"],
      "@vexart/styled": ["./packages/styled/src/index.ts"],
      "@vexart/internal-devtools": ["./packages/internal-devtools/src/index.ts"]
    }
  },
  "include": [
    "packages/*/src/**/*.ts",
    "packages/*/src/**/*.tsx",
    "examples/**/*.ts",
    "examples/**/*.tsx",
    "types/**/*.d.ts"
  ]
}
