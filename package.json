{
  "name": "vexart",
  "version": "0.0.1",
  "description": "Pixel-native terminal rendering engine. Write JSX, get browser-quality UI in your terminal.",
  "type": "module",
  "private": true,
  "workspaces": [
    "packages/*",
    "website"
  ],
  "scripts": {
    "api:update": "rm -rf .api-extractor-temp && tsc -p tsconfig.api.json && bunx api-extractor run --local --config packages/engine/api-extractor.json && bunx api-extractor run --local --config packages/primitives/api-extractor.json && bunx api-extractor run --local --config packages/headless/api-extractor.json && bunx api-extractor run --local --config packages/styled/api-extractor.json",
    "api:check": "bun run api:update",
    "test": "bun test",
    "typecheck": "tsc --noEmit",
    "rust:build": "cargo build --release",
    "rust:test": "cargo test",
    "font:gen": "bun run scripts/gen-font-atlas.ts",
    "build:dist": "bun run scripts/build-dist.ts",
    "bench:lightcode-stage4": "bun run scripts/lightcode-stage4-bench.ts",
    "bench:lightcode-step7-stress": "bun run scripts/lightcode-step7-stress.ts",
    "bench:interaction-latency": "TGE_LOG_FPS=1 bun --conditions=browser run examples/interaction-latency.tsx",
    "bench:lightcode-step9-matrix": "bun run scripts/lightcode-step9-matrix.ts",
    "bench:lightcode-gpu-first-matrix": "bun run scripts/lightcode-gpu-first-layer-matrix.ts",
    "pack": "bun run build:dist && cd dist && bun pack",
    "example": "bun --conditions=browser run examples/hello.tsx",
    "demo3": "bun --conditions=browser run examples/hello.tsx",
    "demo4": "bun --conditions=browser run examples/interactive.tsx",
    "demo5": "bun --conditions=browser run examples/layers.tsx",
    "demo6": "bun --conditions=browser run examples/dashboard.tsx",
    "demo7": "bun --conditions=browser run examples/scroll.tsx",
    "demo8": "bun --conditions=browser run examples/components.tsx",
    "demo9": "bun --conditions=browser run examples/effects.tsx",
    "demo10": "bun --conditions=browser run examples/input.tsx",
    "demo11": "bun --conditions=browser run examples/text-wrap.tsx",
    "ztest": "bun run examples/zindex-test.ts",
    "demo13": "bun --conditions=browser run examples/scroll-programmatic.tsx",
    "demo14": "bun --conditions=browser run examples/textarea.tsx",
    "demo15": "bun --conditions=browser run examples/syntax.tsx",
    "demo16": "bun --conditions=browser run examples/markdown.tsx",
    "demo:virtual-list-scroll": "bun --conditions=browser run examples/virtual-list-scroll-debug.tsx",
    "showcase": "bun --conditions=browser run examples/showcase.tsx",
    "showcase:tab2": "bun --conditions=browser run examples/showcase-tab2.tsx",
    "showcase:tab2:diagnostic": "bun --conditions=browser run examples/showcase-tab2-diagnostic.tsx",
    "demo:gpu": "bun --conditions=browser run examples/gpu-verify.tsx",
    "demo:gpu:perf": "VEXART_LOG_PERF=1 bun --conditions=browser run examples/gpu-verify.tsx",
    "devtools": "bun run packages/internal-devtools/src/server.ts",
    "lint:boundaries": "depcruise packages --config .dependency-cruiser.cjs",
    "gen:jsx-runtime": "bun run scripts/gen-jsx-runtime.ts",
    "test:visual": "bun --conditions=browser run scripts/visual-test/runner.ts",
    "test:visual:update": "bun --conditions=browser run scripts/visual-test/runner.ts --update",
    "test:visual:native-render-graph": "bun --conditions=browser run scripts/visual-test/runner.ts --native-render-graph-parity",
    "perf:baseline": "bun --conditions=browser run scripts/perf-baseline.tsx",
    "perf:check": "bun --conditions=browser run scripts/perf-baseline.tsx --check",
    "bench:frame-breakdown": "bun --conditions=browser run scripts/frame-breakdown.tsx",
    "bench:dashboard-1080p": "bun --conditions=browser run scripts/frame-breakdown.tsx --frames=300 --warmup=5",
    "perf:transport:shm": "bun --conditions=browser run scripts/frame-breakdown.tsx --frames=60 --warmup=5 --transport=shm && bun run scripts/frame-breakdown-gate.ts --transport=shm",
    "perf:transport:file": "bun --conditions=browser run scripts/frame-breakdown.tsx --frames=60 --warmup=5 --transport=file && bun run scripts/frame-breakdown-gate.ts --transport=file",
    "perf:transport:check": "bun run perf:transport:shm && bun run perf:transport:file",
    "perf:frame-orchestrator": "bun --conditions=browser run scripts/frame-orchestrator-bench.ts",
    "check:retained-cleanup": "bun run scripts/check-retained-cleanup.ts",
    "docs:dev": "bun run --cwd website dev",
    "docs:build": "bun run --cwd website build",
    "docs:preview": "bun run --cwd website preview"
  },
  "devDependencies": {
    "@microsoft/api-extractor": "^7.52.10",
    "@babel/core": "^7.29.0",
    "@babel/preset-typescript": "^7.28.5",
    "@napi-rs/canvas": "^0.1.97",
    "@types/bun": "^1.3.12",
    "babel-preset-solid": "^1.9.0",
    "dependency-cruiser": "^16.10.0",
    "esbuild": "^0.28.0",
    "opentype.js": "^1.3.4",
    "solid-js": "^1.9.0",
    "typescript": "^5.7.0"
  },
  "engines": {
    "bun": ">=1.1.0"
  },
  "license": "SEE LICENSE IN LICENSE",
  "dependencies": {
    "@chenglou/pretext": "^0.0.5",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "marked": "^18.0.0",
    "sharp": "^0.34.5",
    "web-tree-sitter": "^0.26.8",
    "zod": "^4.3.6"
  }
}
