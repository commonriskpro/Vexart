{
  "name": "vexart",
  "version": "0.0.1",
  "description": "Pixel-native terminal rendering engine. Write JSX, get browser-quality UI in your terminal.",
  "type": "module",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "test": "bun test",
    "typecheck": "tsc --noEmit",
    "zig:build": "cd zig && zig build -Doptimize=ReleaseFast",
    "zig:test": "cd zig && zig build test --summary all",
    "clay:build": "cc -shared -O2 -o vendor/libclay.dylib -DCLAY_IMPLEMENTATION -DCLAY_DISABLE_SIMD vendor/clay_wrapper.c -I vendor",
    "kitty-shm:build": "sh -c 'mkdir -p native/kitty-shm-helper/build && if [ \"$(uname)\" = Darwin ]; then cc -shared -O2 -o native/kitty-shm-helper/build/libtge_kitty_shm_helper.dylib native/kitty-shm-helper/kitty_shm_helper.c; else cc -shared -O2 -fPIC -o native/kitty-shm-helper/build/libtge_kitty_shm_helper.so native/kitty-shm-helper/kitty_shm_helper.c; fi'",
    "font:gen": "bun run scripts/gen-font-atlas.ts",
    "build:dist": "bun run scripts/build-dist.ts",
    "bench:lightcode-stage4": "bun run scripts/lightcode-stage4-bench.ts",
    "bench:lightcode-step7-stress": "bun run scripts/lightcode-step7-stress.ts",
    "bench:interaction-latency": "TGE_LOG_FPS=1 bun --conditions=browser run examples/interaction-latency.tsx",
    "bench:lightcode-step9-matrix": "bun run scripts/lightcode-step9-matrix.ts",
    "bench:lightcode-gpu-first-matrix": "bun run scripts/lightcode-gpu-first-layer-matrix.ts",
    "pack": "bun run build:dist && cd dist && bun pack",
    "example": "bun --conditions=browser run examples/hello.tsx",
    "demo3": "bun --conditions=browser run examples/hello.tsx",
    "demo4": "bun --conditions=browser run examples/interactive.tsx",
    "demo5": "bun --conditions=browser run examples/layers.tsx",
    "demo6": "bun --conditions=browser run examples/dashboard.tsx",
    "demo7": "bun --conditions=browser run examples/scroll.tsx",
    "demo8": "bun --conditions=browser run examples/components.tsx",
    "demo9": "bun --conditions=browser run examples/effects.tsx",
    "demo10": "bun --conditions=browser run examples/input.tsx",
    "demo11": "bun --conditions=browser run examples/text-wrap.tsx",
    "ztest": "bun run examples/zindex-test.ts",
    "demo13": "bun --conditions=browser run examples/scroll-programmatic.tsx",
    "demo14": "bun --conditions=browser run examples/textarea.tsx",
    "demo15": "bun --conditions=browser run examples/syntax.tsx",
    "demo16": "bun --conditions=browser run examples/markdown.tsx",
    "showcase": "bun --conditions=browser run examples/showcase.tsx",
    "demo:gpu": "bun --conditions=browser run examples/gpu-verify.tsx",
    "demo:gpu:perf": "VEXART_LOG_PERF=1 bun --conditions=browser run examples/gpu-verify.tsx",
    "devtools": "bun run packages/internal-devtools/src/server.ts",
    "lint:boundaries": "depcruise packages --config .dependency-cruiser.cjs"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@babel/preset-typescript": "^7.28.5",
    "@napi-rs/canvas": "^0.1.97",
    "@types/bun": "^1.3.12",
    "babel-preset-solid": "^1.9.0",
    "dependency-cruiser": "^16.10.0",
    "esbuild": "^0.28.0",
    "opentype.js": "^1.3.4",
    "solid-js": "^1.9.0",
    "typescript": "^5.7.0"
  },
  "engines": {
    "bun": ">=1.1.0"
  },
  "license": "MIT",
  "dependencies": {
    "@chenglou/pretext": "^0.0.5",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "marked": "^18.0.0",
    "sharp": "^0.34.5",
    "web-tree-sitter": "^0.26.8",
    "zod": "^4.3.6"
  }
}
